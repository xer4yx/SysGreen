# Normalize line endings: Git stores LF, checks out native on each platform.
* text=auto

# Windows-centric source — keep CRLF on checkout for these.
*.cs       text eol=crlf
*.csproj   text eol=crlf
*.slnx     text eol=crlf
*.xaml     text eol=crlf
*.props    text eol=crlf
*.manifest text eol=crlf

# Treat as binary (no EOL conversion).
*.png binary
*.ico binary
