<Window x:Class="SysGreen.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SysGreen.App"
        mc:Ignorable="d"
        Title="SysGreen" Height="560" Width="900">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top" Text="{Binding Summary}"
                   FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10" />
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding AppVersion}"
                   HorizontalAlignment="Right" Foreground="Gray" FontSize="11" Margin="0,6,2,0" />
        <TabControl>
            <TabItem Header="Recommendations">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Apply selected" Command="{Binding ApplyCommand}" Padding="12,4" />
                        <TextBlock Text="{Binding ApplyStatus}" VerticalAlignment="Center" Margin="12,0,0,0" />
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Recommendations}" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="2">
                                    <Button DockPanel.Dock="Right" Content="Never recommend" Padding="8,1"
                                            Command="{Binding NeverRecommendCommand}"
                                            ToolTip="Always respect this — never suggest disabling it again." />
                                    <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding DisplayText}"
                                              VerticalAlignment="Center" />
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </TabItem>
            <TabItem Header="All Items">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{Binding ApplyStatus}"
                               Foreground="#2E7D32" Margin="2,0,0,6" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AllItemGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4"
                                            Padding="8" Margin="0,0,0,8">
                                        <DockPanel>
                                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                                                <Button DockPanel.Dock="Right" Content="Disable all" Padding="8,2"
                                                        Command="{Binding DisableGroupCommand}" />
                                                <TextBlock Text="{Binding Header}" FontWeight="SemiBold"
                                                           FontSize="14" VerticalAlignment="Center" />
                                            </DockPanel>
                                            <ItemsControl ItemsSource="{Binding Items}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <DockPanel Margin="8,2,0,2">
                                                            <Button DockPanel.Dock="Right" Content="Never recommend"
                                                                    Padding="6,1" Margin="4,0,0,0"
                                                                    Command="{Binding NeverRecommendCommand}" />
                                                            <Button DockPanel.Dock="Right" Content="End task"
                                                                    Padding="8,1" Margin="4,0,0,0"
                                                                    Command="{Binding EndTaskCommand}"
                                                                    ToolTip="Close it now for instant RAM relief — it returns next time it starts." />
                                                            <Button DockPanel.Dock="Right" Content="Disable"
                                                                    Padding="8,1" Margin="4,0,0,0"
                                                                    Command="{Binding DisableCommand}" />
                                                            <ComboBox DockPanel.Dock="Right" Width="130" Margin="4,0,0,0"
                                                                      ItemsSource="{Binding Purposes}"
                                                                      SelectedItem="{Binding SelectedPurpose}"
                                                                      ToolTip="Correct the category — recorded as your override." />
                                                            <TextBlock Text="{Binding DisplayText}" FontFamily="Consolas"
                                                                       VerticalAlignment="Center" />
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>
            <TabItem Header="History">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{Binding HistoryStatus}"
                               Foreground="#2E7D32" Margin="2,0,0,6" />
                    <TextBlock DockPanel.Dock="Top" Foreground="Gray" Margin="2"
                               Text="No changes yet. Anything you disable appears here, fully reversible."
                               Visibility="{Binding HistoryEmpty, Converter={StaticResource BoolToVis}}" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding History}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4"
                                            Padding="8" Margin="0,0,0,8">
                                        <DockPanel>
                                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                                                <Button DockPanel.Dock="Right" Content="Undo batch"
                                                        Command="{Binding UndoCommand}" Padding="8,2" />
                                                <TextBlock Text="{Binding Header}" FontWeight="SemiBold"
                                                           VerticalAlignment="Center" />
                                            </DockPanel>
                                            <ItemsControl ItemsSource="{Binding Items}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <DockPanel Margin="8,2,0,2">
                                                            <Button DockPanel.Dock="Right" MinWidth="84" Padding="8,1"
                                                                    Content="{Binding ReverseLabel}"
                                                                    Command="{Binding ReEnableCommand}" />
                                                            <TextBlock Text="{Binding DisplayText}" FontFamily="Consolas"
                                                                       VerticalAlignment="Center" />
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
