<Window x:Class="SysGreen.App.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="pack://application:,,,/Assets/logo.ico"
        Title="Welcome to SysGreen" Height="430" Width="560"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <DockPanel Margin="24">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,14">
            <Image Source="pack://application:,,,/Assets/logo.ico" Width="36" Height="36"
                   Margin="0,0,12,0" VerticalAlignment="Center" />
            <TextBlock Text="Welcome to SysGreen"
                       FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
        </StackPanel>
        <Button DockPanel.Dock="Bottom" Content="Get started" Command="{Binding ContinueCommand}"
                HorizontalAlignment="Right" Padding="18,6" Margin="0,18,0,0" IsDefault="True" />
        <StackPanel>
            <TextBlock TextWrapping="Wrap" Margin="0,0,0,12"
                       Text="SysGreen helps you reduce what loads at startup — safely and reversibly. Every change is undoable, and a restore point is created before any risky one." />
            <TextBlock Text="Your privacy" FontWeight="SemiBold" Margin="0,4,0,4" />
            <TextBlock TextWrapping="Wrap" Margin="0,0,0,12"
                       Text="To suggest apps you no longer use, SysGreen can note which apps you launch — on this PC only. Nothing is ever uploaded or shared, and the data stays in a local file you control. You can turn this off now, or anytime from the tray icon." />
            <CheckBox IsChecked="{Binding TrackingEnabled}" Margin="0,4,0,0"
                      Content="Track app launches on this PC to improve recommendations (recommended)" />
        </StackPanel>
    </DockPanel>
</Window>
