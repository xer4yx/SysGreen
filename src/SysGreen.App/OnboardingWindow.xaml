<Window x:Class="SysGreen.App.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="pack://application:,,,/Assets/logo.ico"
        Title="Welcome to SysGreen" Height="600" Width="600"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize" MinHeight="460" MinWidth="480">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <DockPanel Margin="22">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <Image Source="pack://application:,,,/Assets/logo.ico" Width="36" Height="36"
                   Margin="0,0,12,0" VerticalAlignment="Center" />
            <TextBlock Text="Welcome to SysGreen"
                       FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
        </StackPanel>

        <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Margin="0,0,0,10"
                   Text="SysGreen helps you reduce what loads at startup — safely and reversibly. Please review the Privacy Policy &amp; Terms below, then accept to continue." />

        <Button DockPanel.Dock="Bottom" Content="I accept and continue" Command="{Binding ContinueCommand}"
                HorizontalAlignment="Right" Padding="18,6" Margin="0,14,0,0" IsDefault="True" />

        <!-- First run only: launch-tracking consent (ADR-0012). Hidden on a version-bump re-prompt. -->
        <CheckBox DockPanel.Dock="Bottom" IsChecked="{Binding TrackingEnabled}" Margin="0,12,0,0"
                  Visibility="{Binding IsFirstRun, Converter={StaticResource BoolToVis}}"
                  Content="Track app launches on this PC to improve recommendations (recommended)" />

        <Border BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4">
            <TextBox Text="{Binding PolicyText, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap"
                     BorderThickness="0" Background="Transparent" Padding="10"
                     VerticalScrollBarVisibility="Auto" FontFamily="Segoe UI" FontSize="12" />
        </Border>
    </DockPanel>
</Window>
