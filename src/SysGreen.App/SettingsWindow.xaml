<Window x:Class="SysGreen.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Icon="pack://application:,,,/Assets/logo.ico"
        Title="SysGreen — Settings" Height="560" Width="520"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="Section" TargetType="Border">
            <Setter Property="BorderBrush" Value="#DDDDDD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Gray" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,3,0,0" />
        </Style>
        <Style x:Key="ComingSoon" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#B26A00" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontStyle" Value="Italic" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="8,0,0,0" />
        </Style>
    </Window.Resources>
    <DockPanel Margin="14">
        <TextBlock DockPanel.Dock="Top" Text="Settings" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
        <TextBlock DockPanel.Dock="Bottom" HorizontalAlignment="Right" Foreground="Gray" FontSize="11"
                   Margin="0,6,2,0" Text="{Binding AppVersion}" />

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Launch tracking (ADR-0012) -->
                <Border Style="{StaticResource Section}">
                    <StackPanel>
                        <CheckBox Content="Track app launches on this PC" FontWeight="SemiBold"
                                  IsChecked="{Binding LaunchTrackingEnabled}" />
                        <TextBlock Style="{StaticResource Hint}"
                                   Text="Powers habit-based recommendations. Local-only — nothing leaves this machine. Turning it off keeps recommendations to the curated Knowledge Base." />
                    </StackPanel>
                </Border>

                <!-- Uninstall data retention (ADR-0017) -->
                <Border Style="{StaticResource Section}">
                    <StackPanel>
                        <CheckBox Content="Keep my data if I uninstall SysGreen" FontWeight="SemiBold"
                                  IsChecked="{Binding KeepDataOnUninstall}" />
                        <TextBlock Style="{StaticResource Hint}"
                                   Text="Your history and settings live outside the install folder, so they survive an uninstall and reinstall. Uncheck to have them removed when you uninstall." />
                    </StackPanel>
                </Border>

                <!-- Reset (ADR-0017 in-app clean slate) -->
                <Border Style="{StaticResource Section}">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Reset my data" Padding="10,3"
                                VerticalAlignment="Top" Click="ResetData_Click" />
                        <StackPanel>
                            <TextBlock Text="Reset my data" FontWeight="SemiBold" />
                            <TextBlock Style="{StaticResource Hint}"
                                       Text="Clears your history, usage, overrides, and settings on this PC. This can't be undone." />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Uninstall (ADR-0017 option C: choose keep/delete here, then launch the uninstaller) -->
                <Border Style="{StaticResource Section}">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Uninstall SysGreen…" Padding="10,3"
                                VerticalAlignment="Top" Click="Uninstall_Click" />
                        <StackPanel>
                            <TextBlock Text="Uninstall SysGreen" FontWeight="SemiBold" />
                            <TextBlock Style="{StaticResource Hint}"
                                       Text="Removes SysGreen from this PC. You'll choose whether to keep or delete your saved data first." />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Coming soon (Phase 5) -->
                <TextBlock Text="Coming soon" FontWeight="SemiBold" Foreground="Gray" Margin="2,4,0,6" />

                <Border Style="{StaticResource Section}">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Text="Feature coming soon…" Style="{StaticResource ComingSoon}" DockPanel.Dock="Right" />
                            <TextBlock Text="Recommend apps I haven't used in a while" FontWeight="SemiBold" />
                        </DockPanel>
                        <Slider Minimum="7" Maximum="90" Value="30" IsEnabled="False" Margin="0,6,0,0" />
                        <TextBlock Style="{StaticResource Hint}"
                                   Text="Choose how many days of no use marks an app as abandoned (default 30)." />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Section}">
                    <DockPanel>
                        <TextBlock Text="Feature coming soon…" Style="{StaticResource ComingSoon}" DockPanel.Dock="Right" />
                        <Button Content="View privacy policy &amp; terms" Padding="10,3" IsEnabled="False"
                                HorizontalAlignment="Left" DockPanel.Dock="Left" />
                    </DockPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
