<Window x:Class="SysGreen.App.PolicyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="pack://application:,,,/Assets/logo.ico"
        Title="SysGreen — Privacy Policy &amp; Terms" Height="620" Width="560"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="14">
        <Button DockPanel.Dock="Bottom" Content="Close" HorizontalAlignment="Right" Padding="16,5"
                Margin="0,10,0,0" Click="Close_Click" IsCancel="True" IsDefault="True" />
        <TextBox x:Name="PolicyBody" IsReadOnly="True" TextWrapping="Wrap" BorderThickness="0"
                 Background="Transparent" VerticalScrollBarVisibility="Auto"
                 FontFamily="Segoe UI" FontSize="12" Padding="2" />
    </DockPanel>
</Window>
